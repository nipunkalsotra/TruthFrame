# Copy this file to .env and fill in your actual keys
# .env is gitignored — never commit real keys to this repo

# Required: Google AI Studio key (free at https://aistudio.google.com)
GOOGLE_API_KEY=AIza...

# Required: Groq key (free at https://console.groq.com)
GROQ_API_KEY=gsk_...

# Optional overrides (defaults shown)
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_RPM_LIMIT=14
GEMINI_TPM_LIMIT=1000000
GROQ_RPM_LIMIT=30
GROQ_TPM_LIMIT=30000
